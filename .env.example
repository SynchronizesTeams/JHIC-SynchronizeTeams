# VAPID Keys for Web Push Notifications
# Public key used in client-side (browser)
NUXT_PUBLIC_VAPID_PUBLIC_KEY=

# Add private key if need server-side push in the future
# VAPID_PRIVATE_KEY=cvxYrX6nZSER8iteYjskUj5l6i-SABTztzjKzwPHG28

# API Configuration
NUXT_PUBLIC_API_BASE_URL=https://penus.synchronizeteams.com/api
NUXT_PUBLIC_API_VERSION=v1

# API Endpoints (optional - untuk override specific endpoints)
NUXT_PUBLIC_API_AUTH_ENDPOINT=auth
NUXT_PUBLIC_API_NEWS_ENDPOINT=news
NUXT_PUBLIC_API_USER_LINKS_ENDPOINT=user-links
NUXT_PUBLIC_API_FORUM_ENDPOINT=forum
NUXT_PUBLIC_API_EVENT_ENDPOINT=event
NUXT_PUBLIC_API_IMAGE_ENDPOINT=image
NUXT_PUBLIC_API_PORTAL_ENDPOINT=portal
NUXT_PUBLIC_API_GUEST_BOOK_ENDPOINT=guest-book
NUXT_PUBLIC_API_MADING_ENDPOINT=mading
NUXT_PUBLIC_API_TEACHER_ENDPOINT=teacher
NUXT_PUBLIC_API_ESKUL_ENDPOINT=eskul
NUXT_PUBLIC_API_ACHIEVEMENT_ENDPOINT=achievement
NUXT_PUBLIC_API_INDUSTRY_ENDPOINT=industry
NUXT_PUBLIC_API_CERTIFICATION_ENDPOINT=certification
NUXT_PUBLIC_API_TESTIMONIAL_ENDPOINT=testimonial

# Development Configuration
NUXT_PUBLIC_USE_PROXY=true
NUXT_PUBLIC_PROXY_TARGET=http://127.0.0.1:3001

# App Configuration
NUXT_PUBLIC_APP_NAME="SMK Plus Pelita Nusantara"
NUXT_PUBLIC_APP_URL=https://smkpluspelitanusantara.sch.id
NUXT_PUBLIC_APP_DESCRIPTION="SMK Plus Pelita Nusantara - Sekolah Menengah Kejuruan Terbaik"

# Social Media
NUXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/smkpelitanusantara
NUXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/smkpelitanusantara
NUXT_PUBLIC_TWITTER_URL=https://twitter.com/smkpelitanusantara
NUXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/smkpelitanusantara

# Features Toggle
NUXT_PUBLIC_ENABLE_NEWS=true
NUXT_PUBLIC_ENABLE_FORUMS=true
NUXT_PUBLIC_ENABLE_EVENTS=true
NUXT_PUBLIC_ENABLE_GALLERY=true
NUXT_PUBLIC_ENABLE_PORTAL=true

# Push Notifications (optional)
NUXT_PUBLIC_VAPID_PUBLIC_KEY=

# Development/Debug
NUXT_PUBLIC_DEBUG_MODE=false
NUXT_PUBLIC_LOG_API_CALLS=false
